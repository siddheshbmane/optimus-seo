// Optimus SEO - Prisma Schema
// Version: 1.0 | Date: 2026-03-19
// Based on SCHEMA.md specification

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  owner
  admin
  strategist
  executive
  sales
  viewer
}

enum ProjectStatus {
  created
  sales_phase
  strategy_phase
  execution_phase
  reporting
  completed
  paused
  archived
}

enum ApprovalStatus {
  pending
  approved
  rejected
  revision_requested
}

enum ContentStatus {
  draft
  in_review
  revision_needed
  approved
  published
  archived
}

enum AgentStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum KeywordType {
  short_tail
  long_tail
  generic
  branded
}

enum KeywordIntent {
  commercial
  informational
  navigational
  transactional
}

enum BacklinkType {
  directory
  profile
  social_bookmarking
  image_submission
  guest_post
  resource_page
  forum
  comment
  web2
  press_release
}

enum SubmissionStatus {
  queued
  scheduled
  submitting
  submitted
  pending_approval
  approved
  rejected
  failed
}

enum AuditIssueSeverity {
  critical
  high
  medium
  low
  info
}

enum ReportFormat {
  pdf
  ppt
  html
}

enum GmbPostType {
  update
  offer
  event
  product
}

enum NotificationChannel {
  in_app
  email
  slack
  webhook
}

enum LlmProvider {
  anthropic
  openai
  google
  mistral
  cohere
  deepseek
  groq
}

// ============================================================================
// CORE TABLES
// ============================================================================

model Organization {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String    @db.VarChar(255)
  slug                  String    @unique @db.VarChar(100)
  logoUrl               String?   @db.Text
  primaryColor          String?   @default("#FD8C73") @db.VarChar(7)
  customDomain          String?   @unique @db.VarChar(255)
  
  // Stripe billing
  stripeCustomerId      String?   @db.VarChar(255)
  stripeSubscriptionId  String?   @db.VarChar(255)
  subscriptionStatus    String    @default("trial") @db.VarChar(50)
  planId                String?   @db.Uuid
  trialEndsAt           DateTime?
  
  // DataForSEO credentials (encrypted)
  dataforseoLogin       String?   @db.Text
  dataforseoPassword    String?   @db.Text
  monthlyApiBudget      Int?      // in cents
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  // Relations
  plan                  PricingPlan?           @relation(fields: [planId], references: [id])
  users                 User[]
  projects              Project[]
  apiKeys               ApiKey[]
  integrations          Integration[]
  orgSettings           OrgSetting[]
  contentReviewCriteria ContentReviewCriteria[]
  notifications         Notification[]

  @@index([slug], name: "idx_org_slug")
  @@index([stripeCustomerId], name: "idx_org_stripe")
}

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String?   @db.Uuid
  email           String    @unique @db.VarChar(255)
  name            String    @db.VarChar(255)
  avatarUrl       String?   @db.Text
  emailVerified   Boolean   @default(false)
  role            UserRole  @default(executive)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // Relations
  organization    Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions        Session[]
  accounts        Account[]
  createdProjects Project[]         @relation("ProjectCreator")
  notifications   Notification[]
  approvalQueue   ApprovalQueue[]   @relation("ApprovalAssignee")
  reviewedItems   ApprovalQueue[]   @relation("ApprovalReviewer")
  approvedBriefs  ContentBrief[]    @relation("BriefApprover")
  approvedStructures WebsiteStructure[] @relation("StructureApprover")
  approvedStrategies LinkBuildingStrategy[] @relation("StrategyApprover")
  approvedGmbPosts GmbPost[]        @relation("GmbPostApprover")
  createdPitchDecks PitchDeck[]
  createdReports  ClientReport[]

  @@index([email], name: "idx_user_email")
  @@index([organizationId], name: "idx_user_org")
  @@index([organizationId, role], name: "idx_user_org_role")
}

model Account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String    @db.Uuid
  accountId             String    @db.VarChar(255)
  providerId            String    @db.VarChar(255)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  idToken               String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_account_user")
}

model Session {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  token       String   @unique @db.VarChar(500)
  expiresAt   DateTime
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token], name: "idx_session_token")
  @@index([userId], name: "idx_session_user")
  @@index([expiresAt], name: "idx_session_expires")
}

// Better Auth Verification table (for magic links, email verification, etc.)
// Note: Better Auth expects string IDs, not UUIDs
model Verification {
  id         String   @id @default(cuid())
  identifier String   @db.VarChar(255)  // email or other identifier
  value      String   @db.Text          // verification token
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier], name: "idx_verification_identifier")
  @@index([value], name: "idx_verification_value")
}

model ApiKey {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String      @db.Uuid
  provider        LlmProvider
  encryptedKey    String      @db.Text
  label           String?     @db.VarChar(100)
  isActive        Boolean     @default(true)
  lastUsedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, provider], name: "idx_apikey_org_provider")
}

model Integration {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @db.Uuid
  type            String   @db.VarChar(50) // google_search_console, google_analytics, google_business_profile
  accessToken     String?  @db.Text
  refreshToken    String?  @db.Text
  tokenExpiresAt  DateTime?
  accountId       String?  @db.VarChar(255)
  metadata        Json     @default("{}")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type], name: "idx_integration_org_type")
}

// ============================================================================
// PROJECT TABLES
// ============================================================================

model Project {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String        @db.Uuid
  name            String        @db.VarChar(255)
  clientUrl       String        @db.VarChar(500)
  industry        String?       @db.VarChar(100)
  description     String?       @db.Text
  status          ProjectStatus @default(created)
  healthScore     Int?
  createdById     String?       @db.Uuid
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  // Relations
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       User?                 @relation("ProjectCreator", fields: [createdById], references: [id])
  locations       ProjectLocation[]
  competitors     Competitor[]
  settings        ProjectSetting[]
  
  // Sales Phase
  siteAudits      SiteAudit[]
  keywordOverviews KeywordOverview[]
  competitorOverviews CompetitorOverview[]
  ppcIntelligence PpcIntelligence[]
  aiVisibilityChecks AiVisibilityCheck[]
  gmbAnalyses     GmbAnalysis[]
  pitchDecks      PitchDeck[]
  proposals       Proposal[]
  
  // Strategy Phase
  keywords        Keyword[]
  keywordClusters KeywordCluster[]
  competitorAnalyses CompetitorAnalysis[]
  websiteStructures WebsiteStructure[]
  suggestedPages  SuggestedPage[]
  contentBriefs   ContentBrief[]
  linkBuildingStrategies LinkBuildingStrategy[]
  
  // Execution Phase
  contents        Content[]
  backlinkOpportunities BacklinkOpportunity[]
  backlinkSubmissions BacklinkSubmission[]
  onPageTasks     OnPageTask[]
  gmbPosts        GmbPost[]
  gmbReviewResponses GmbReviewResponse[]
  outreachCampaigns OutreachCampaign[]
  
  // Reporting Phase
  rankTrackingConfig RankTrackingConfig?
  rankTrackings   RankTracking[]
  trafficData     TrafficData[]
  aiVisibilityReports AiVisibilityReport[]
  clientReports   ClientReport[]
  shareOfVoice    ShareOfVoice[]
  
  // System
  agentTasks      AgentTask[]
  approvalQueue   ApprovalQueue[]

  @@index([organizationId], name: "idx_project_org")
  @@index([organizationId, status], name: "idx_project_org_status")
}

model Location {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationCode        Int      @unique
  locationName        String   @db.VarChar(255)
  locationType        String   @db.VarChar(50) // Country, Region, City, DMA
  countryCode         String?  @db.VarChar(5)
  countryName         String?  @db.VarChar(100)
  parentLocationCode  Int?
  languageCode        String?  @db.VarChar(10)
  languageName        String?  @db.VarChar(100)

  // Relations
  projectLocations    ProjectLocation[]

  @@index([locationCode], name: "idx_location_code")
  @@index([countryCode], name: "idx_location_country")
}

model ProjectLocation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @db.Uuid
  locationId  String   @db.Uuid
  isPrimary   Boolean  @default(false)

  // Relations
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  location    Location @relation(fields: [locationId], references: [id])

  @@unique([projectId, locationId])
  @@index([projectId], name: "idx_projloc_project")
}

model Competitor {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String   @db.Uuid
  url             String   @db.VarChar(500)
  name            String?  @db.VarChar(255)
  isAutoDiscovered Boolean @default(false)
  domainAuthority Int?
  organicTraffic  Int?
  createdAt       DateTime @default(now())

  // Relations
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  overviews       CompetitorOverview[]
  analyses        CompetitorAnalysis[]

  @@index([projectId], name: "idx_competitor_project")
}

// ============================================================================
// SALES PHASE TABLES
// ============================================================================

model SiteAudit {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId               String   @db.Uuid
  organizationId          String   @db.Uuid
  healthScore             Int?
  pagesCrawled            Int      @default(0)
  lighthousePerformance   Float?
  lighthouseAccessibility Float?
  lighthouseSeo           Float?
  lighthouseBestPractices Float?
  coreWebVitals           Json     @default("{}")
  mobileScore             Float?
  desktopScore            Float?
  schemaMarkupFound       Json     @default("[]")
  toxicBacklinksCount     Int?
  rawData                 Json     @default("{}")
  summaryNarrative        String?  @db.Text
  agentTaskId             String?  @db.Uuid
  createdAt               DateTime @default(now())

  // Relations
  project                 Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues                  SiteAuditIssue[]
  agentTask               AgentTask?       @relation(fields: [agentTaskId], references: [id])

  @@index([projectId], name: "idx_audit_project")
  @@index([organizationId], name: "idx_audit_org")
}

model SiteAuditIssue {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteAuditId     String             @db.Uuid
  severity        AuditIssueSeverity
  category        String             @db.VarChar(100)
  title           String             @db.VarChar(500)
  description     String             @db.Text
  pageUrl         String?            @db.VarChar(500)
  recommendation  String?            @db.Text
  isFixed         Boolean            @default(false)

  // Relations
  siteAudit       SiteAudit          @relation(fields: [siteAuditId], references: [id], onDelete: Cascade)

  @@index([siteAuditId], name: "idx_auditissue_audit")
  @@index([siteAuditId, severity], name: "idx_auditissue_severity")
}

model KeywordOverview {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String        @db.Uuid
  organizationId    String        @db.Uuid
  keyword           String        @db.VarChar(500)
  serpPosition      Int?
  searchVolume      Int?
  estimatedTraffic  Float?
  cpc               Float?
  difficulty        Int?
  keywordType       KeywordType?
  intent            KeywordIntent?
  hasFeaturedSnippet Boolean      @default(false)
  paaQuestions      Json          @default("[]")
  createdAt         DateTime      @default(now())

  // Relations
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], name: "idx_kwoverview_project")
  @@index([organizationId], name: "idx_kwoverview_org")
}

model CompetitorOverview {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String   @db.Uuid
  organizationId    String   @db.Uuid
  competitorId      String?  @db.Uuid
  domainAuthority   Int?
  totalBacklinks    Int?
  referringDomains  Int?
  organicKeywords   Int?
  estimatedTraffic  Int?
  trafficCost       Float?
  linkGapDomains    Json     @default("[]")
  contentGapKeywords Json    @default("[]")
  shareOfVoice      Float?
  createdAt         DateTime @default(now())

  // Relations
  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  competitor        Competitor? @relation(fields: [competitorId], references: [id])

  @@index([projectId], name: "idx_compoverview_project")
}

model PpcIntelligence {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId             String   @db.Uuid
  organizationId        String   @db.Uuid
  totalEstimatedAdSpend Float?
  topAdvertisers        Json     @default("[]")
  keywordAdData         Json     @default("[]")
  bingAdData            Json     @default("[]")
  adCopyExamples        Json     @default("[]")
  createdAt             DateTime @default(now())

  // Relations
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], name: "idx_ppc_project")
}

model AiVisibilityCheck {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId           String   @db.Uuid
  organizationId      String   @db.Uuid
  aiVisibilityScore   Int?
  mentionsChatgpt     Int      @default(0)
  mentionsClaude      Int      @default(0)
  mentionsGemini      Int      @default(0)
  mentionsPerplexity  Int      @default(0)
  totalImpressions    Int      @default(0)
  topMentionedDomains Json     @default("[]")
  topCitedPages       Json     @default("[]")
  recommendations     String?  @db.Text
  rawData             Json     @default("{}")
  createdAt           DateTime @default(now())

  // Relations
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], name: "idx_aivisibility_project")
}

model GmbAnalysis {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String   @db.Uuid
  organizationId  String   @db.Uuid
  businessName    String?  @db.VarChar(255)
  rating          Float?
  reviewCount     Int      @default(0)
  reviewSentiment Json     @default("{}")
  categories      Json     @default("[]")
  isInLocalPack   Boolean  @default(false)
  napConsistency  Json     @default("{}")
  competitorGmb   Json     @default("[]")
  localSeoScore   Int?
  rawData         Json     @default("{}")
  createdAt       DateTime @default(now())

  // Relations
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], name: "idx_gmb_project")
}

model PitchDeck {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String       @db.Uuid
  organizationId  String       @db.Uuid
  version         Int          @default(1)
  filePath        String?      @db.Text
  format          ReportFormat @default(ppt)
  status          String       @default("generating") @db.VarChar(50)
  sentAt          DateTime?
  createdById     String?      @db.Uuid
  createdAt       DateTime     @default(now())

  // Relations
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy       User?        @relation(fields: [createdById], references: [id])

  @@index([projectId], name: "idx_pitch_project")
}

model Proposal {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String   @db.Uuid
  organizationId  String   @db.Uuid
  scopeOfWork     String?  @db.Text
  recommendedPlan String?  @db.VarChar(100)
  timeline        String?  @db.Text
  pricing         Json     @default("{}")
  filePath        String?  @db.Text
  status          String   @default("draft") @db.VarChar(50)
  createdAt       DateTime @default(now())

  // Relations
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], name: "idx_proposal_project")
}

// ============================================================================
// STRATEGY PHASE TABLES
// ============================================================================

model Keyword {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String        @db.Uuid
  organizationId    String        @db.Uuid
  clusterId         String?       @db.Uuid
  keyword           String        @db.VarChar(500)
  searchVolume      Int?
  difficulty        Int?
  cpc               Float?
  competition       Float?
  keywordType       KeywordType?
  intent            KeywordIntent?
  funnelStage       String?       @db.VarChar(50)
  priorityScore     Float?
  currentPosition   Int?
  monthlyTrend      Json          @default("[]")
  hasFeaturedSnippet Boolean      @default(false)
  paaQuestions      Json          @default("[]")
  isTarget          Boolean       @default(false)
  isCannibalized    Boolean       @default(false)
  isDecaying        Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cluster           KeywordCluster? @relation(fields: [clusterId], references: [id])
  rankTrackings     RankTracking[]

  @@index([projectId], name: "idx_keyword_project")
  @@index([organizationId], name: "idx_keyword_org")
  @@index([clusterId], name: "idx_keyword_cluster")
  @@index([projectId, isTarget], name: "idx_keyword_project_target")
}

model KeywordCluster {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String        @db.Uuid
  name            String        @db.VarChar(255)
  pillarKeyword   String?       @db.VarChar(500)
  intent          KeywordIntent?
  keywordCount    Int           @default(0)
  totalVolume     Int           @default(0)
  avgDifficulty   Float?
  priorityScore   Float?
  topicalAuthority String?      @db.VarChar(50)
  createdAt       DateTime      @default(now())

  // Relations
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keywords        Keyword[]

  @@index([projectId], name: "idx_kwcluster_project")
}

model CompetitorAnalysis {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId           String   @db.Uuid
  organizationId      String   @db.Uuid
  competitorId        String?  @db.Uuid
  backlinkProfile     Json     @default("{}")
  contentStrategy     Json     @default("{}")
  topPages            Json     @default("[]")
  technicalComparison Json     @default("{}")
  sponsoredKeywords   Json     @default("[]")
  estimatedAdSpend    Float?
  linkSources         Json     @default("{}")
  serpFeatureOwnership Json    @default("{}")
  createdAt           DateTime @default(now())

  // Relations
  project             Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  competitor          Competitor? @relation(fields: [competitorId], references: [id])

  @@index([projectId], name: "idx_companalysis_project")
}

model WebsiteStructure {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId           String         @db.Uuid
  organizationId      String         @db.Uuid
  currentSitemap      Json           @default("{}")
  orphanPages         Json           @default("[]")
  thinContentPages    Json           @default("[]")
  competitorSitemaps  Json           @default("{}")
  gapAnalysis         Json           @default("{}")
  idealSitemap        Json           @default("{}")
  urlStructure        String?        @db.Text
  internalLinkingPlan Json           @default("{}")
  schemaStrategy      Json           @default("{}")
  status              ApprovalStatus @default(pending)
  approvedById        String?        @db.Uuid
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Relations
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedBy          User?           @relation("StructureApprover", fields: [approvedById], references: [id])
  suggestedPages      SuggestedPage[]

  @@index([projectId], name: "idx_webstructure_project")
}

model SuggestedPage {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  websiteStructureId  String   @db.Uuid
  projectId           String   @db.Uuid
  pageType            String   @db.VarChar(100)
  suggestedUrl        String?  @db.VarChar(500)
  title               String   @db.VarChar(255)
  purpose             String?  @db.Text
  targetKeywords      Json     @default("[]")
  competitorReference Json     @default("[]")
  priority            Int      @default(0)
  status              String   @default("suggested") @db.VarChar(50)
  createdAt           DateTime @default(now())

  // Relations
  websiteStructure    WebsiteStructure @relation(fields: [websiteStructureId], references: [id], onDelete: Cascade)
  project             Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentBrief        ContentBrief?

  @@index([websiteStructureId], name: "idx_sugpage_structure")
  @@index([projectId], name: "idx_sugpage_project")
}

model ContentBrief {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  suggestedPageId     String         @unique @db.Uuid
  projectId           String         @db.Uuid
  organizationId      String         @db.Uuid
  primaryKeyword      String         @db.VarChar(500)
  secondaryKeywords   Json           @default("[]")
  searchIntent        KeywordIntent?
  titleTag            String?        @db.VarChar(70)
  metaDescription     String?        @db.VarChar(170)
  headingStructure    Json           @default("[]")
  contentSections     Json           @default("[]")
  wordCountTarget     Int            @default(1500)
  internalLinks       Json           @default("[]")
  externalLinks       Json           @default("[]")
  mediaSuggestions    Json           @default("[]")
  ctaPlacements       Json           @default("[]")
  faqSection          Json           @default("[]")
  schemaMarkup        String?        @db.VarChar(100)
  competitorAnalysis  Json           @default("{}")
  seoScoringCriteria  Json           @default("{}")
  status              ApprovalStatus @default(pending)
  approvedById        String?        @db.Uuid
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Relations
  suggestedPage       SuggestedPage  @relation(fields: [suggestedPageId], references: [id], onDelete: Cascade)
  project             Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedBy          User?          @relation("BriefApprover", fields: [approvedById], references: [id])
  contents            Content[]

  @@index([projectId], name: "idx_brief_project")
}

